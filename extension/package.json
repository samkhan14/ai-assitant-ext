{
  "name": "ai-dev-assistant",
  "displayName": "AI Dev Assistant",
  "description": "A professional AI assistant sidebar panel with Ask and Agent modes.",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "*",
    "onView:aiDevAssistant.panel",
    "onCommand:aiDevAssistant.openPanel"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ai-dev-assistant",
          "title": "AI Dev Assistant",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "ai-dev-assistant": [
        {
          "type": "webview",
          "id": "aiDevAssistant.panel",
          "name": "AI Dev Assistant"
        }
      ]
    },
    "commands": [
      {
        "command": "aiDevAssistant.openPanel",
        "title": "Open AI Dev Assistant"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@types/node": "^20.0.0",
    "typescript": "^5.3.0"
  }
}
